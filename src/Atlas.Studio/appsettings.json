{
  // Atlas Studio — runtime configuration.
  // Changes here take effect on next restart.
  //
  // Environment variables prefixed ATLAS__ (double underscore) override any value here.
  // Example: ATLAS__BaseUrl=http://localhost:8080

  "Atlas": {
    // The llama-server base URL. Overridden by the ATLAS_BASE_URL env var for
    // compatibility with the old convention.
    "BaseUrl": "http://localhost:8080",

    // ------------------------------------------------------------------ Chat
    "Chat": {
      // Sampling temperature (0 = deterministic, higher = more varied).
      "Temperature": 0.7,
      // Hard cap on generated output tokens. 0 = use the per-task budget.
      // Raise this (e.g. 2048) if short answers get cut off mid-sentence.
      "MaxOutputTokens": 0,
      // The system prompt prepended to every chat request.
      "SystemPrompt": "You are Atlas, a careful local study assistant for the mnemo app. Answer clearly and concisely. If you are unsure, say so rather than inventing facts."
    },

    // --------------------------------------------------------------- Web search
    // Provider choices: "DuckDuckGo" (default, no setup), "Searxng", "Brave", "None"
    "WebSearch": {
      "Provider": "DuckDuckGo",
      // SearXNG only: the URL of your self-hosted instance, e.g. "http://localhost:8888"
      "BaseUrl": "",
      // Brave only: your API key from https://brave.com/search/api (free tier available)
      "ApiKey": "",
      "DefaultMaxResults": 5,
      "ResultLimit": 10
    },

    // ------------------------------------------------------------------- MCP
    // External MCP servers Atlas launches as subprocesses.
    // Each server's tools appear in the Tools screen under its configured branch.
    //
    // Example — official MCP test server (needs Node.js + npm):
    //   {
    //     "Id": "everything",
    //     "Command": "npx",
    //     "Arguments": ["-y", "@modelcontextprotocol/server-everything"],
    //     "Branch": "External",
    //     "Enabled": true
    //   }
    //
    // Example — read files under the repo (needs Node.js + npm):
    //   {
    //     "Id": "fs",
    //     "Command": "npx",
    //     "Arguments": ["-y", "@modelcontextprotocol/server-filesystem", "C:\\your\\path"],
    //     "Branch": "Files",
    //     "Enabled": true
    //   }
    "Mcp": {
      "ProtocolVersion": "2024-11-05",
      "RequestTimeoutSeconds": 30,
      "Servers": []
    }
  }
}
