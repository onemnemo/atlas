{
  // Atlas CLI — runtime configuration.
  // Environment variables prefixed ATLAS__ (double underscore) override these.
  // ATLAS_BASE_URL env var is also respected for the inference URL.

  "Atlas": {
    "BaseUrl": "http://localhost:8080",

    "Chat": {
      "Temperature": 0.7,
      "MaxOutputTokens": 0,
      "SystemPrompt": "You are Atlas, a careful local study assistant for the mnemo app. Answer clearly and concisely. If you are unsure, say so rather than inventing facts."
    },

    "WebSearch": {
      "Provider": "DuckDuckGo",
      "BaseUrl": "",
      "ApiKey": "",
      "DefaultMaxResults": 5,
      "ResultLimit": 10
    },

    "Mcp": {
      "ProtocolVersion": "2024-11-05",
      "RequestTimeoutSeconds": 30,
      "Servers": []
    }
  }
}
